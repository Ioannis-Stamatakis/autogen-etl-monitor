{
  "name": "sales_transactions",
  "columns": {
    "transaction_id": {"type": "string", "required": true, "unique": true},
    "customer_id": {"type": "string", "required": true},
    "product_id": {"type": "string", "required": true},
    "quantity": {"type": "integer", "required": true, "min": 1, "max": 10000},
    "unit_price": {"type": "float", "required": true, "min": 0.01, "max": 100000.0},
    "currency": {"type": "string", "required": true, "allowed_values": ["USD", "EUR", "GBP", "CAD", "AUD"]},
    "transaction_date": {"type": "date", "required": true},
    "region": {"type": "string", "required": true, "allowed_values": ["North", "South", "East", "West"]},
    "status": {"type": "string", "required": true, "allowed_values": ["completed", "refunded", "pending", "failed"]}
  }
}
